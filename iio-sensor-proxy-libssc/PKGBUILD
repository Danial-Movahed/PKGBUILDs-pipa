prepare() {
  cd $_pkgname-$pkgver

  for p in ../*.patch; do
    [[ -f "$p" ]] || continue
    echo "Applying patch: $p"
    patch -Np1 -i "$p"
  done
}

build() {
  mkdir $_pkgname-$pkgver/build
  cd $_pkgname-$pkgver/build

  arch-meson .. \
    -Dsystemdsystemunitdir=/usr/lib/systemd/system \
    -Db_lto=true \
		-Dssc-support=enabled

  ninja
}

check() {
  cd $_pkgname-$pkgver/build
}

package() {
  provides=(iio-sensor-proxy)
  conflicts=(iio-sensor-proxy)
  
  cd $_pkgname-$pkgver/build
   
  DESTDIR="$pkgdir" ninja install

  # Make iio-sensor-proxy depend on hexagonrpcd
  install -Dm644 "$srcdir"/system-iio-sensor-proxy.service.d-hexagonrpcd.conf \
		"$pkgdir"/usr/lib/systemd/system/iio-sensor-proxy.service.d/hexagonrpcd.conf

  # Add override for it to always restart
  install -d "$pkgdir/etc/systemd/system/iio-sensor-proxy.service.d"
  cat > "$pkgdir/etc/systemd/system/iio-sensor-proxy.service.d/override.conf" <<EOF
[Service]
Restart=always
RestartSec=5
EOF
  
}

